{
    "name": "ftp-client",
    "version": "0.5.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "check": "tsc",
        "format:check": "prettier --check .",
        "format:fix": "prettier --write .",
        "validate": "pnpm run lint && pnpm run check && pnpm run format:check && pnpm run test run && pnpm audit --audit-level=high && echo 'Validation passed!'",
        "server:build": "cd server && node esbuild.config.js",
        "server:start": "cd server && node bundle.js",
        "server:build+start": "pnpm run server:build && pnpm run server:start"
    },
    "dependencies": {
        "@sayari/eslint-plugin": "0.0.1-rc.4",
        "@uiw/react-codemirror": "^4.25.10",
        "@zip.js/zip.js": "2.8.26",
        "basic-ftp": "^6.0.1",
        "bootstrap": "^5.3.8",
        "bootstrap-icons": "^1.13.1",
        "eventemitter3": "^5.0.4",
        "jszip": "^3.10.1",
        "monaco-editor": "0.55.1",
        "monaco-editor-textmate": "^4.0.0",
        "monaco-textmate": "^3.0.1",
        "onigasm": "^2.2.5",
        "pako": "^2.1.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "ssh2-sftp-client": "^12.1.1",
        "ws": "^8.21.0",
        "zustand": "^5.0.14"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/bootstrap": "^5.2.11",
        "@types/node": "^25.9.1",
        "@types/pako": "^2.0.4",
        "@types/react": "^19.2.16",
        "@types/react-dom": "^19.2.3",
        "@types/ssh2-sftp-client": "^9.0.6",
        "@types/wicg-file-system-access": "^2023.10.7",
        "@types/ws": "^8.18.1",
        "@vitejs/plugin-react": "^6.0.2",
        "@vitest/ui": "^4.1.8",
        "esbuild": "^0.28.1",
        "eslint": "^10.4.1",
        "eslint-import-resolver-typescript": "^4.4.5",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-path": "^2.1.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-unused-imports": "^4.4.1",
        "happy-dom": "^20.9.0",
        "prettier": "3.8.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.1",
        "vite": "^8.0.16",
        "vitest": "^4.1.8"
    }
}
