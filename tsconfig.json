{
    "compilerOptions": {
        "module": "ES2020",
        "target": "ES2022",
        "noEmit": true,
        "jsx": "react-jsx",
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true,
        "strict": false,
        "types": [
            "vite/client",
            "react",
            "react-dom",
            "@types/wicg-file-system-access"
        ],
        "paths": {
            "@common/*": ["./src/common/*"],
            "@protocol/*": ["./src/protocol/*"],
            "@web/*": ["./src/web/*"],
            "@server/*": ["./src/server/*"]
        }
    },
    "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"],
    "exclude": ["node_modules", "vendor", "types"]
}
